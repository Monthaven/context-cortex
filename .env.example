# Context Cortex — Environment Variables
# These are used when cortex.config.json is not present.
# Copy this file to .env and fill in your values.

# Database
CORTEX_DB_HOST=localhost
CORTEX_DB_PORT=5432
CORTEX_DB_NAME=postgres
CORTEX_DB_USER=postgres
CORTEX_DB_PASSWORD=
CORTEX_DB_SSL=false

# Ollama (embedding generation)
CORTEX_OLLAMA_HOST=http://localhost:11434
CORTEX_OLLAMA_MODEL=nomic-embed-text
CORTEX_OLLAMA_ENABLED=true

# Server
CORTEX_PORT=3131
CORTEX_HOST=0.0.0.0
CORTEX_API_KEY=

# Config file path (default: ./cortex.config.json)
CORTEX_CONFIG=./cortex.config.json
